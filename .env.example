# CoinGlass API（备选数据源）
COINGLASS_API_KEY=your_coinglass_api_key

# 监控参数
THRESHOLD_PERCENT=1.0
CHECK_INTERVAL=60
WINDOW_MINUTES=10

# 邮件配置
EMAIL_ENABLED=true
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USE_SSL=true
SENDER_EMAIL=your_email@163.com
SENDER_PASSWORD=your_smtp_authorization_code
RECEIVER_EMAIL=your_email@163.com
