# CoinGlass API（备选数据源，免费计划暂不支持）
COINGLASS_API_KEY=

# 窗口1：5 分钟波动 ≥ $10
WINDOW_1_MINUTES=5
WINDOW_1_THRESHOLD=10

# 窗口2：10 分钟波动 ≥ $20
WINDOW_2_MINUTES=10
WINDOW_2_THRESHOLD=20

# 冷却时间（分钟）
COOLDOWN_1_MINUTES=15
COOLDOWN_2_MINUTES=30

# 邮件配置
EMAIL_ENABLED=true
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USE_SSL=true
SENDER_EMAIL=your_email@163.com
SENDER_PASSWORD=your_smtp_authorization_code
RECEIVER_EMAIL=your_email@163.com
